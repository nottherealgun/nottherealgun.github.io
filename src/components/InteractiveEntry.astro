---
const { title, description, image, link, datetime, index } = Astro.props;
---

<div class="entry" id="interactive-entry" style={`animation-delay: ${index * 0.1}s`}>
    <div class="p-4 border-2 border-primary w-fit bg-primary text-secondary relative top-6">
        <h1 class="text-xl lg:text-2xl">{title}</h1>
    </div>
    <div class="flex flex-col gap-6 bg-secondary w-full p-4 pt-10 shadow-xl">
        <p>{description}</p>
    </div>
</div>

<style>
    .entry {
        animation: fadeIn 0.5s ease forwards;
        opacity: 0;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>