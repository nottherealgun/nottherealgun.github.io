---
import '../styles/global.css';
import { Icon } from 'astro-icon/components'

const rawPath = Astro.url.pathname
const slugs = rawPath.split('/').filter(Boolean);
---

<div class="p-4 fixed w-full z-10">
    <div class="flex flex-row p-4 bg-white items-center justify-left shadow-2xl transition-all hover:rounded-4xl">
        <a class="flex" onclick="history.back()" href="">
            <Icon name="mdi:keyboard-arrow-left" class="w-8 h-auto"/>
        </a>
        <a class="flex" href="/">
            <Icon name="mdi:home" class="w-8 h-auto"/>
        </a>
        <div id="nav-path-container" class="flex flex-row">
            {slugs.map((slug) => (
                <div class="flex flex-row items-center">
                    <Icon name="mdi:keyboard-arrow-right"/>
                    <p class="text-black">{slug}</p>
                </div>
            ))}
        </div>

    </div>
</div>