---
import type Index from "../pages/index.astro";
import "../styles/global.css";
import { Icon } from "astro-icon/components";

const rawPath = Astro.url.pathname;
const slugs = rawPath.split("/").filter(Boolean);

const additiveSlugs = [slugs[0]] as string[];

const { pageTitle } = Astro.props;

slugs.forEach((slug, index) => {
  if (index === 0) {
    return;
  }

  additiveSlugs.push(additiveSlugs[index - 1] + "/" + slug);
});
---

<div class="p-4 fixed w-full z-10">
  <div
    class="flex flex-row p-4 bg-white items-center justify-left shadow-xl transition-all hover:rounded-4xl"
  >
    <a class="flex hover:cursor-pointer lg:mr-4" onclick="history.back()">
      <Icon name="mdi:arrow-left" class="w-8 h-auto" />
    </a>
    <a class="flex" href="/">
      <Icon name="mdi:home" class="w-8 h-auto" />
    </a>
    <div id="nav-path-container" class="flex flex-row overflow-y-scroll">
      {
        slugs.map((slug, index) => (
          <div class="flex flex-row items-center">
            <Icon name="mdi:keyboard-arrow-right" />
            <a
              class="text-primary text-nowrap text-ellipsis"
              href={"../" + additiveSlugs[index]}
            >
              {additiveSlugs[index].includes("posts/")
                ? pageTitle
                : slug[0].toUpperCase() + slug.substring(1).toLowerCase()}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</div>
