---
import '../styles/global.css';
import { Icon } from 'astro-icon/components'
import Button from '../components/Button.astro';

let dynamicText = "";
---


<div class="flex flex-col m-auto">
	<div class="flex items-center justify-center h-svh">
		<div class="flex flex-col items-left gap-3 lg:gap-5">
			<div class="flex flex-col text-[2rem] lg:text-6xl lg:gap-3">
				<h1 class="text-[4rem] lg:text-8xl">Hello,</h1>
				<h1>My name is <span class="font-extrabold bg-primary text-white px-2 rounded-lg lg:px-4 lg:rounded-2xl">Gun</span></h1>
			</div>
			<div class="flex flex-row opacity-50">
				<p class="lg:text-3xl">I am <span id="rotating-text">a game developer</span><span id="blinking-cursor">_</span></p>
			</div>
		</div>
	</div>
	<div class="flex flex-col h-svh bg-primary items-center justify-center py-10">
		<div class="flex flex-col w-[80%] lg:w-[90%] max-w-[40em] gap-y-2">

			<Button buttonText="Projects" icon="mdi:flower-tulip" link="/projects" index="1"/>
			<Button buttonText="Resume & Portfolio" icon="mdi:person-box" link="/portfolio" index="2"/>
			<Button buttonText="Articles" icon="mdi:file-document" link="/articles" index="3"/>
			<Button buttonText="Extras" icon="mdi:shape-plus" link="/extras" index="4"/>

			<div class="pt-20 text-secondary w-full opacity-50">
				<div class="flex flex-col gap-2 lg:flex-wrap lg:flex-row lg:justify-center-safe">
					<div class="flex flex-row items-center gap-2">
						<Icon name="mdi:email"/>
						<p>thanapat.nart@gmail.com</p>
					</div>
					<div class="flex flex-row items-center gap-2">
						<Icon name="mdi:linkedin"/>
						<p>Thanapat Nartthanarung</p>
					</div>
					<div class="flex flex-row items-center gap-2">
						<Icon name="mdi:facebook"/>
						<p>Thanapat Nartthanarung</p>
					</div>
					<div class="flex flex-row items-center gap-2">
						<Icon name="bluesky"/>
						<p>nottherealgun.bsky.social</p>
					</div>
					<div class="flex flex-row items-center gap-2">
						<Icon name="mdi:github"/>
						<p>nottherealgun</p>
					</div>
					<div class="flex flex-row items-center gap-2">
						<Icon name="itchio"/>
						<p>nottherealgun</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	const sleep = (ms: number) => new Promise(r => setTimeout(r, ms));

	const rotatingTextElement = document.querySelector('#rotating-text') as HTMLParagraphElement;
	const blinkingCursorElement = document.querySelector('#blinking-cursor') as HTMLSpanElement;

	const year = new Date().getFullYear();

	const texts = [
		"a game developer",
		"a game designer",
		"a graphic designer",
		"a UX/UI designer",
		"a front-end developer",
		"a programmer",
		"a lifelong learner",
		"a Thai national",
		"a Bangkok resident",
		"an MUIC alumnus",
		"an international student",
		"bilingual",
		"not a Chinese speaker",
		"not a firearm",
		"a Minecraft player",
		"an Anime lover",
		"a FOSS software advocate",
		"a Reddit user",
		"a Bluesky user",
		"a Facebook user",
		year - 2004 + " years old",
		"still a Windows user",
		"an Android user",
		"a Godot user",
		"trying out Raylib",
		"trying out Astro",
		"trying out Hugo",
		"trying out Three.js",
		"re-typing this every 5 seconds",
		"non-religious by heart",
	];

	let index = 0;
	let nextText = texts[index];

	setInterval(() => {
		index = (index + 1) % texts.length;
		nextText = texts[index];
		TypeText();
	}, 5000);

	setInterval(() => {
		Blink();
	}, 200);

	async function TypeText(){
		while(rotatingTextElement.textContent.length > 0){
			rotatingTextElement.textContent = rotatingTextElement.textContent.slice(0, -1);
			await sleep(50);
		}
		await sleep(250);
		while(rotatingTextElement.textContent.length < nextText.length){
			rotatingTextElement.textContent += nextText[rotatingTextElement.textContent.length];
			await sleep(100);
		}
	}

	function Blink(){
		blinkingCursorElement.style.visibility = blinkingCursorElement.style.visibility === 'hidden' ? 'visible' : 'hidden';
	}

</script>