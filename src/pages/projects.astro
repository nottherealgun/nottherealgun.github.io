---
import "../styles/global.css";
import NavLayout from "../layouts/NavLayout.astro";
import CategoryButton from "../components/CategoryButton.astro";

let buttons = [
  {
    icon: "mdi:controller",
    buttonText: "Games and Interactives",
    link: "/projects/interactives",
    disabled: false,
  },
  {
    icon: "mdi:checkbox-intermediate-variant",
    buttonText: "Interface Designs",
    link: "/projects/interfaces",
    disabled: false,
  },
  {
    icon: "mdi:drawing",
    buttonText: "Graphic Designs",
    link: "/projects/graphics",
    disabled: true,
  },
  {
    icon: "mdi:art",
    buttonText: "Doodles and Sketches",
    link: "/projects/art",
    disabled: true,
  },
];
---

<NavLayout pageTitle="Projects">
  <div class="flex flex-col m-auto">
    <div
      class="flex flex-col gap-6 items-center-safe justify-center min-h-svh bg-linear-to-t from-primary to-purple-600 lg:gap-8"
    >
      <div class="flex text-secondary">
        <h1 class="text-2xl lg:text-4xl">My Projects</h1>
      </div>
      <div class="flex flex-row gap-4">
        <div class="flex flex-col gap-2 lg:flex-row">
          {
            buttons.map((button, index) => (
              <CategoryButton
                icon={button.icon}
                buttonText={button.buttonText}
                link={button.link}
                index={index}
                disabled={button.disabled}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</NavLayout>
