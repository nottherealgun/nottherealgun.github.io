---
import "../../styles/global.css";
import NavLayout from "../../layouts/NavLayout.astro";
import Set from "../../components/projects/interactives/Set.astro";
import json from "../../assets/projects/interactives.json";
---

<NavLayout pageTitle="Interactives">
  <div class="flex flex-col pt-30">
    <div class="mx-auto w-[80%] max-w-[40em] lg:w-full lg:max-w-[90%]">
      <Set
        headerTitle="Games"
        headerIcon="mdi:controller"
        entries={json.games}
      />
      <Set
        headerTitle="Websites"
        headerIcon="mdi:web-asset"
        entries={json.websites}
      />
      <Set
        headerTitle="Apps & Software"
        headerIcon="mdi:settings-applications"
        entries={json.software}
      />
    </div>
  </div>
</NavLayout>
